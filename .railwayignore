# Railway uses this file in preference to .gitignore for the upload.
# Same exclusions as .dockerignore. Parquet now ships from a GitHub
# Release at Docker build time (see Dockerfile), so the local upload
# is just code (~2 MB).

.git
.venv
venv
__pycache__
*.pyc

node_modules
**/node_modules
.next
.turbo

# Big raw data we don't want in the upload.
data/raw
data/duckdb
data/cache
data/figures

# Parquet ships from a GitHub Release fetched at image-build time.
data/parquet

# Web app isn't run from this image, but the workspace install needs
# web/package.json. Exclude the heavy bits and keep only the manifest.
web/.next
web/node_modules
web/app
web/components
web/lib
web/public
web/scripts
web/styles
web/test

# Eval + recording artifacts.
agent/recordings
agent/eval/cassettes

# Local-only.
docs
*.pdf
*.log
*.duckdb
*.duckdb.wal
.DS_Store
.vscode
.idea
.vercel
