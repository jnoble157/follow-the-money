# Things we DO want in the image: the source for agent, mcp, plus parquet.
# Things we DON'T want: web build artifacts, raw data, eval recordings,
# anything Python.

.git
.venv
venv
__pycache__
*.pyc

node_modules
**/node_modules
.next
.turbo

# Parquet is fetched from a GitHub Release at image-build time, not
# copied from the build context.
data/raw
data/parquet
data/duckdb
data/cache
data/figures

# Web app isn't run from this image, but the workspace install needs
# web/package.json present.
web/.next
web/node_modules
web/app
web/components
web/lib
web/public
web/scripts
web/styles
web/test

# Eval + recording artifacts that aren't needed at runtime.
agent/recordings
agent/eval/cassettes

# Local-only tooling and editor scratch.
docs
*.pdf
*.log
*.duckdb
*.duckdb.wal
.DS_Store
.vscode
.idea
.vercel
