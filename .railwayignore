# Railway uses this file in preference to .gitignore for the upload.
# Same exclusions as .dockerignore, but explicitly NOT excluding
# data/parquet/ (which the repo .gitignore strips), since the Dockerfile
# bakes it into the image.

.git
.venv
venv
__pycache__
*.pyc

node_modules
**/node_modules
.next
.turbo

# Big raw data we don't want in the upload.
data/raw
data/duckdb
data/cache
data/figures

# Local-only full parquet kept as a backup; we ship trimmed versions.
data/parquet/tec_trim
**/*.full.parquet

# Web app isn't run from this image, but the workspace install needs
# web/package.json. Exclude the heavy bits and keep only the manifest.
web/.next
web/node_modules
web/app
web/components
web/lib
web/public
web/scripts
web/styles
web/test

# Eval + recording artifacts.
agent/recordings
agent/eval/cassettes

# Local-only.
docs
*.pdf
*.log
*.duckdb
*.duckdb.wal
.DS_Store
.vscode
.idea
.vercel
